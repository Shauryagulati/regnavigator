from typing import List, Dict, Any, Optional, Tuple
import hashlib
import numpy as np
from FlagEmbedding import BGEM3FlagModel
import torch
from .config import BGE_M3_MODEL

def _stable_token_to_int(tok: str) -> int:
    return int(hashlib.md5(tok.encode("utf-8")).hexdigest()[:12], 16)

def _normalize_sparse(weights: Optional[Dict[Any, float]]) -> Dict[str, List[float]]:
    if not weights:
        return {"indices": [], "values": []}
    indices, values = [], []
    for k, v in weights.items():
        if isinstance(k, int):
            idx = k
        elif isinstance(k, str):
            try:
                idx = int(k)
            except ValueError:
                idx = _stable_token_to_int(k)
        else:
            idx = int(k)
        indices.append(idx)
        values.append(float(v))
    return {"indices": indices, "values": values}

def _l2_normalize(mat: np.ndarray, axis: int = 1, eps: float = 1e-12) -> np.ndarray:
    norms = np.linalg.norm(mat, axis=axis, keepdims=True)
    norms = np.maximum(norms, eps)
    return mat / norms

class EmbeddingModel:
    def __init__(self, model_name: str = BGE_M3_MODEL, device: Optional[str] = None,
                 use_fp16: Optional[bool] = None, batch_size: int = 16, max_length: int = 8192):
        if device is None:
            device = "cuda" if torch.cuda.is_available() else "cpu"
        if use_fp16 is None:
            use_fp16 = device == "cuda"
        self.model = BGEM3FlagModel(model_name, use_fp16=use_fp16, device=device)
        self.batch_size = batch_size
        self.max_length = max_length

    def _encode(self, texts: List[str]) -> Tuple[List[List[float]], List[Dict[str, List[float]]]]:
        out = self.model.encode(texts, batch_size=self.batch_size, max_length=self.max_length,
                               return_dense=True, return_sparse=True)
        dense = out.get("dense_vecs")
        if dense is None:
            raise ValueError("BGE-M3 did not return dense_vecs")
        
        lexical = None
        for key in ["lexical_weights", "sparse_vecs", "lexical_vecs"]:
            if key in out:
                lexical = out[key]
                break
        
        sparse = [_normalize_sparse(w) for w in lexical] if lexical else [{"indices": [], "values": []} for _ in dense]
        
        if len(sparse) != len(dense):
            while len(sparse) < len(dense):
                sparse.append({"indices": [], "values": []})
            sparse = sparse[:len(dense)]
        
        dense_np = _l2_normalize(np.array(dense, dtype=np.float32), axis=1)
        return dense_np.tolist(), sparse

    def encode_texts(self, texts: List[str]) -> Dict[str, Any]:
        dense, sparse = self._encode(texts)
        return {"dense": dense, "sparse": sparse}

    def encode_query(self, text: str) -> Dict[str, Any]:
        dense, sparse = self._encode([text])
        return {"dense": dense[0], "sparse": sparse[0]}
